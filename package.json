{
  "name": "ccmonitor",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "bin": {
    "ccmonitor": "src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --compile --outfile dist/ccmonitor",
    "install:global": "bun run scripts/install.ts"
  },
  "dependencies": {
    "chokidar": "^4.0.0"
  }
}
